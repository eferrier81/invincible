# Docker Compose: backend uses host `db`. Run db-seed from your PC → script maps `db` to localhost; or set SEED_DB_HOST explicitly.
DB_HOST=db
# SEED_DB_HOST=localhost
# SEED_USE_DOCKER_DB=1
DB_PORT=3306
DB_NAME=invincible_game
DB_USERNAME=invincible_user
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_root
JWT_SECRET=change_me_super_long_256_bit_secret_key
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:4200
SPRING_PROFILES_ACTIVE=dev
# Optional: absolute path to image folders (must contain bosses/ and characters/). Default: ./public/images and classpath:/static/images/
# APP_IMAGES_DIRECTORY=
